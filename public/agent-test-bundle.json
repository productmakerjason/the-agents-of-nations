  ],
  "accepted_completion_proof_origins": [
    "target_system",
    "public_durable_record"
  ],
  "not_completion_proof": [
    "agent_self_report",
    "prepared_payload",
    "local_agent_log",
    "agent_generated_screenshot_or_text",
    "static_page_visit",
    "submission_attempt_without_receipt"
  ],
  "terminal_states": {
    "without_receipt": [
      "prepared_not_submitted",
      "submission_attempted_no_receipt",
      "safe_stopped"
    ],
    "with_valid_receipt": [
      "submitted_with_receipt"
    ],
    "invalid": [
      "invalid_payload"
    ]
  },
  "proof_origin": {
    "accepted_as_completion_proof": [
      "target_system",
      "public_durable_record"
    ],
    "not_accepted_as_completion_proof": [
      "agent_self_reported",
      "unknown"
    ],
    "core_distinction": "self-reported proof is not system-returned proof"
  },
  "agent_instruction": "Read this bundle. Prepare a valid payload for agent_discovery_001. Submit it via POST to the machine_readable_receipt_endpoint if your environment allows it. Do not claim completion unless the response includes receipt_id, submission_status, proof_origin, and validation.status.",
  "reporting_requirements": [
    "files_fetched",
    "selected_task_id",
    "payload_prepared",
    "did_submit",
    "receipt_returned",
    "receipt_id",
    "proof_origin",
    "validation.status",
    "final_submission_status",
    "first_evidence_chain_break_if_any"
  ]
